# Power Tech Security — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=strong_password_here

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=strong_redis_password

# ─── JWT ─────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_MIN_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
# development | staging | production

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://app.powertech.ph

# ─── Email (SendGrid or SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@powertech.ph
EMAIL_FROM_NAME=Power Tech Security

# ─── SMS (Infobip — Philippines coverage) ────────────────────────────
SMS_PROVIDER=infobip
SMS_API_KEY=your_infobip_api_key
SMS_BASE_URL=https://xxxxxx.api.infobip.com
SMS_SENDER=PowerTech

# ─── WhatsApp Business API ───────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ─── Firebase (Push Notifications) ───────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# ─── Elasticsearch ───────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_API_KEY=

# ─── File Storage ─────────────────────────────────────────────────────
# local | s3 | gcs
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/media
# For S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=powertech-media

# ─── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
